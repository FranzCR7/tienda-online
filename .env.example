# ─── Entorno de ejecución ────────────────────────────────────────────────────
# Opciones: desarrollo | pruebas | produccion
FLASK_ENV=desarrollo
FLASK_APP=run.py

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-secreta-antes-de-produccion

# ─── Base de Datos (PostgreSQL) ───────────────────────────────────────────────
# Formato: postgresql://usuario:contrasena@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tienda_online_dev

# ─── Base de Datos de Pruebas ─────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tienda_online_test

# ─── Render (se configura automáticamente en producción) ─────────────────────
# DATABASE_URL=<proporcionada-por-render>
# PORT=10000
